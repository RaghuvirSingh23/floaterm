{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "floaterm",
  "version": "2.0.0",
  "identifier": "com.raghuvirsingh.floaterm",
  "build": {
    "frontendDist": "http://localhost:2323",
    "devUrl": "http://localhost:2323",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "floaterm",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
